# =============================================================================
# Borgmatic API Nextcloud AIO - Configuration
# =============================================================================

# --- Mode de sécurité ---
# true: tokens à 3 rôles + flags ENABLE_* obligatoires
# false (défaut): mode legacy compatible (API_TOKEN unique)
SECURE_MODE=false

# --- Tokens API (mode sécurisé) ---
# API_ADMIN_TOKEN: accès complet (admin, config, lock break, passphrase, etc.)
API_ADMIN_TOKEN=change-me-admin

# API_ACTION_TOKEN: accès limité aux actions prédéfinies uniquement
# C'est le token à donner à Node-RED
API_ACTION_TOKEN=change-me-action

# API_READ_TOKEN: lecture seule (statut, health, polling jobs, logs)
API_READ_TOKEN=change-me-read

# --- Token API (mode legacy, ignoré si SECURE_MODE=true) ---
# API_TOKEN=legacy-token

# --- Flags de sécurité (mode sécurisé) ---
# Contrôle quels endpoints dangereux sont accessibles même avec API_ADMIN_TOKEN.
# Node-RED avec API_ACTION_TOKEN ne peut JAMAIS accéder à ces endpoints.

# Accès aux endpoints admin (emergency shutdown, etc.)
ENABLE_ADMIN_ENDPOINTS=true

# Écriture/suppression de configurations borgmatic
ENABLE_CONFIG_WRITE=true

# Cassure de locks Borg
ENABLE_BREAK_LOCK=true

# Changement de passphrase de dépôt
ENABLE_PASSPHRASE_CHANGE=true

# Cibles de sauvegarde arbitraires (run-for-target, backup-target POST)
# Si false, Node-RED ne peut que déclencher des actions prédéfinies
ENABLE_ARBITRARY_TARGETS=true

# --- Chemin vers le fichier de politiques d'actions ---
# Format YAML, une action par clé de premier niveau
ACTIONS_POLICY_FILE=/data/actions-policy.yaml

# --- Audit log ---
# Chemin vers le fichier audit (si vide, stdout uniquement)
AUDIT_LOG_PATH=
# Si true, écrit aussi sur stdout
AUDIT_STDOUT=true

# --- Configuration Nextcloud AIO ---
AIO_MASTER_CONTAINER=nextcloud-aio-mastercontainer
AIO_DAILY_BACKUP_SCRIPT=/daily-backup.sh
AIO_HEALTHCHECK_SCRIPT=/healthcheck
AIO_BORGBACKUP_CONTAINER=nextcloud-aio-borgbackup
AIO_CONFIG_FILE=/data/nextcloud-aio/config.json

# --- Chemins Borgmatic ---
BORG_CONFIG_DIR=/data/borgmatic/config
BORG_BASE_DIR=/data/borgmatic
BORG_SSH_DIR=/data/borgmatic/ssh

# --- Docker ---
DOCKER_HOST=
USE_SOCKET_PROXY=false

# --- SSE ---
SSE_HEARTBEAT_SEC=15
SSE_BASE_URL=
READY_WEBHOOK_URL=

# --- Timeouts ---
DAILY_STOP_TIMEOUT=60